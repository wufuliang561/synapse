# OpenRouter API Key
# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Supabase Configuration for Frontend (Vite requires VITE_ prefix)
# Get these from your Supabase project settings
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase Configuration for Server-side API functions
# These need to be duplicated with different prefixes for Vercel functions
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase Service Role Key (for API authentication)
# This is needed for server-side API endpoints to verify JWT tokens
# Get from Supabase Dashboard -> Settings -> API -> service_role key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here